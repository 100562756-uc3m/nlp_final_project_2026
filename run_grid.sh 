#!/bin/bash
EVAL="evaluation/dailymed_eval_v2.jsonl"
INDEX="data/vector_db/smart_index"
OUT="evaluation/grid_results"

for K in 3 5 10; do
  for T in 0.20 0.25 0.30 0.35 0.40; do
    echo "Running k=$K threshold=$T"
    python scripts/evaluate_rag.py \
      --eval-set $EVAL \
      --index $INDEX \
      --top-k $K \
      --score-threshold $T \
      --output-dir $OUT
  done
done

echo "Done. Results in $OUT"


